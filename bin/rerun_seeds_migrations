#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="$(cd -- "$(dirname "${BASH_SOURCE}")" ; cd .. > /dev/null 2>&1 && pwd -P)"
cd $PROJECT_DIR
export RAILS_ENV=test
source bin/db-set-env

export DISABLE_DATABASE_ENVIRONMENT_CHECK=1

# seeds (only seeds, like the core vocab)
dropdb -e -f --if-exists $PGDATABASE
./bin/create-db -e $PGDATABASE
bundle exec rails db:migrate
bundle exec rails db:seed

# migrate/seed produce audit trail noise (e.g. UPDATE/INSERT auth_systems);
# clear it so the dump starts with a clean audit history
psql -d $PGDATABASE -c "TRUNCATE audited_changes, audited_requests, audited_responses"

rm -f db/seeds.pgbin
bundle exec rails db:pg:structure_and_data:dump FILE=db/seeds.pgbin


